# ── Токены ботов ─────────────────────────────────
TELEGRAM_BOT_TOKEN=токен_Мери_от_BotFather
SAM_BOT_TOKEN=токен_Сэма_от_BotFather
MISS_IVES_BOT_TOKEN=токен_МиссАйвз_от_BotFather

# ── Чат "Штаб" (опционально) ─────────────────────
# Можно не заполнять — достаточно написать /sethq в группе со всеми тремя ботами
# Если хочешь прописать вручную:
# HQ_CHAT_ID=-100xxxxxxxxxx

# ── AI и голос ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ASSEMBLYAI_API_KEY=...

# ── База данных ───────────────────────────────────
# PostgreSQL от Railway (Add Service → Database → PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Логи (опционально) ────────────────────────────
# ID личного чата куда Мери дублирует диалоги
LOG_CHAT_ID=

# ── Деплой на Railway (опционально) ──────────────
# WEBHOOK_URL=https://your-app.railway.app
# PORT=8080
